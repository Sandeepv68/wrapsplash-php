{
    "name": "sandeepv/wrapsplash-php",
    "description": "A PHP API wrapper for the Unsplash platform",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sandeep Vattapparambil",
            "email": "sandeepv@live.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SandeepV\\WrapsplashPHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SandeepV\\WrapsplashPHP\\Tests\\": "tests/"
        }
    },
    "keywords": ["unsplash", "api", "photos", "images", "wrapper"],
    "minimum-stability": "stable",
    "prefer-stable": true
}
